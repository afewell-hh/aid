package aid:core@0.1.0;

// LEGACY / NON-LIVE (#84): pre-rebuild WIT surface retained for quarantine and the
// #38 consistency guard only. The Rust hhfab wiring adapter this describes was
// RETIRED in F7d (#64/#35); the live wiring is the Go internal/wiring renderer over
// the F2/F3 boundary (D23). Does NOT specify a live boundary. Retire-vs-reconcile
// is deferred to a follow-up.

/// Layer 2 — hhfab wiring export adapter (Rust WASM component).
///
/// Consumes `topology-ir` ONLY. It must never read plan YAML, query NetBox, or
/// perform other I/O — it is a pure transformation from IR to wiring YAML.
interface hhfab-adapter {
  use types.{topology-ir};

  /// Export options.
  record hhfab-options {
    /// Restrict output to a single fabric by name; `none` exports all fabrics.
    fabric: option<string>,
    /// When true, emit one document per managed fabric instead of one combined
    /// document.
    split-by-fabric: bool,
  }

  /// One emitted wiring document. `fabric` is the fabric name the document
  /// covers (or a combined-scope label when not split).
  record wiring-document {
    fabric: string,
    /// hhfab wiring YAML (Kubernetes CRD format, wiring.githedgehog.com).
    yaml: string,
  }

  record hhfab-output {
    documents: list<wiring-document>,
  }

  variant hhfab-error {
    /// The IR contains a topology shape the adapter cannot express.
    unsupported-topology(string),
    /// The IR was structurally invalid (e.g. edge referencing an unknown node).
    invalid-ir(string),
    /// Unexpected internal failure.
    internal(string),
  }

  /// Produce wiring YAML document(s) from a calculated topology IR.
  export-wiring: func(ir: topology-ir, options: hhfab-options)
    -> result<hhfab-output, hhfab-error>;
}
