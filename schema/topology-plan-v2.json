{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aid.opencompute.org/schema/topology-plan-v2.json",
  "title": "AID Topology Plan (v2)",
  "description": "The topology-plan shape for the rebuilt AID foundation (docs/foundation-redesign.md §4.1, D18/D21). A document is EITHER the real diet/XOC 9-section EXTERNAL shape (reference_data co-located; ingested + split losslessly into the catalog) OR the AID-canonical PURE-REFERENCE shape (meta + spec [+ status]) that references catalog classes by pinned id+version. The `oneOf` makes these mutually exclusive, so a malformed spec/status is rejected (it matches neither branch). status/expected is a self-check oracle only — it never drives production calculation (guardrail 3).",
  "oneOf": [
    { "$ref": "#/$defs/external_plan" },
    { "$ref": "#/$defs/canonical_plan" }
  ],
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["case_id", "name"],
      "properties": {
        "case_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "version": { "type": "integer" },
        "managed_by": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },

    "ref": {
      "type": "object",
      "description": "Pinned catalog reference: id name + version (+ optional digest). Guardrail 1.",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "digest": { "type": "string" }
      }
    },

    "counts": {
      "type": "object",
      "properties": {
        "server_classes": { "type": "integer", "minimum": 0 },
        "switch_classes": { "type": "integer", "minimum": 0 },
        "connections": { "type": "integer", "minimum": 0 }
      }
    },

    "external_plan": {
      "type": "object",
      "description": "The real diet/XOC 9-section bundled shape (no spec/status; reference_data co-located).",
      "required": ["meta"],
      "not": { "anyOf": [ { "required": ["spec"] }, { "required": ["status"] } ] },
      "properties": {
        "meta": { "$ref": "#/$defs/meta" },
        "reference_data": {
          "type": "object",
          "properties": {
            "manufacturers": { "type": "array", "items": { "type": "object" } },
            "device_types": { "type": "array", "items": { "type": "object" } },
            "device_type_extensions": { "type": "array", "items": { "type": "object" } },
            "breakout_options": { "type": "array", "items": { "type": "object" } },
            "module_types": { "type": "array", "items": { "type": "object" } }
          }
        },
        "plan": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "enum": ["draft", "review", "approved", "exported"] },
            "description": { "type": "string" }
          }
        },
        "switch_classes": { "type": "array", "items": { "$ref": "#/$defs/external_switch_class" } },
        "switch_port_zones": { "type": "array", "items": { "$ref": "#/$defs/zone" } },
        "server_classes": { "type": "array", "items": { "$ref": "#/$defs/external_server_class" } },
        "server_nics": { "type": "array", "items": { "$ref": "#/$defs/server_nic" } },
        "server_connections": { "type": "array", "items": { "$ref": "#/$defs/connection" } },
        "expected": { "$ref": "#/$defs/expected_block" }
      }
    },

    "canonical_plan": {
      "type": "object",
      "description": "AID-canonical: meta + spec (pure-reference intent) + optional status/expected.",
      "required": ["meta", "spec"],
      "additionalProperties": false,
      "properties": {
        "meta": { "$ref": "#/$defs/meta" },
        "spec": { "$ref": "#/$defs/spec" },
        "status": { "$ref": "#/$defs/status" }
      }
    },

    "spec": {
      "type": "object",
      "required": ["server_classes"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "server_classes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["server_class_id", "class_ref", "quantity"],
            "additionalProperties": false,
            "properties": {
              "server_class_id": { "type": "string" },
              "class_ref": { "$ref": "#/$defs/ref" },
              "quantity": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "switch_classes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["switch_class_id", "class_ref", "fabric_name"],
            "additionalProperties": false,
            "properties": {
              "switch_class_id": { "type": "string" },
              "class_ref": { "$ref": "#/$defs/ref" },
              "fabric_name": { "type": "string", "minLength": 1 },
              "override_quantity": { "type": "integer", "minimum": 0 },
              "topology_mode": { "type": "string", "enum": ["spine-leaf", "mesh"] }
            }
          }
        },
        "switch_port_zones": { "type": "array", "items": { "$ref": "#/$defs/zone" } },
        "server_connections": { "type": "array", "items": { "$ref": "#/$defs/connection" } },
        "mesh_links": { "type": "array", "items": { "type": "object" } },
        "mclag_domains": { "type": "array", "items": { "type": "object" } }
      }
    },

    "status": {
      "type": "object",
      "description": "Computed/expected plane (self-check only — guardrail 3).",
      "additionalProperties": false,
      "properties": {
        "expected": { "$ref": "#/$defs/status_block" },
        "computed": { "$ref": "#/$defs/status_block" }
      }
    },
    "status_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "counts": { "$ref": "#/$defs/counts" },
        "switch_quantity": { "type": "object", "additionalProperties": { "type": "integer" } }
      }
    },
    "expected_block": {
      "type": "object",
      "properties": { "counts": { "$ref": "#/$defs/counts" } }
    },

    "external_switch_class": {
      "type": "object",
      "required": ["fabric_name"],
      "properties": {
        "switch_class_id": { "type": "string" },
        "id": { "type": "string" },
        "fabric_name": { "type": "string", "minLength": 1 },
        "fabric_class": { "type": "string", "enum": ["managed", "unmanaged"] },
        "hedgehog_role": { "type": "string" },
        "device_type_extension": { "type": "string" },
        "topology_mode": { "type": "string", "enum": ["spine-leaf", "mesh"] },
        "override_quantity": { "type": "integer", "minimum": 0 },
        "uplink_ports_per_switch": { "type": "integer", "minimum": 0 },
        "mclag_pair": { "type": "boolean" },
        "redundancy_type": { "type": "string", "enum": ["mclag", "eslag"] },
        "redundancy_group": { "type": "string" },
        "groups": { "type": "array", "items": { "type": "string" } }
      }
    },
    "external_server_class": {
      "type": "object",
      "required": ["quantity"],
      "properties": {
        "server_class_id": { "type": "string" },
        "id": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "integer", "minimum": 1 },
        "gpus_per_server": { "type": "integer", "minimum": 0 },
        "server_device_type": { "type": "string" }
      }
    },
    "server_nic": {
      "type": "object",
      "required": ["server_class", "nic_id", "module_type"],
      "properties": {
        "server_class": { "type": "string" },
        "nic_id": { "type": "string" },
        "module_type": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "zone": {
      "type": "object",
      "required": ["switch_class", "zone_name", "zone_type", "port_spec"],
      "properties": {
        "switch_class": { "type": "string" },
        "zone_name": { "type": "string" },
        "zone_type": { "type": "string", "enum": ["server", "uplink", "mclag", "peer", "session", "oob", "fabric", "mesh"] },
        "port_spec": { "type": "string" },
        "breakout_option": { "type": "string" },
        "allocation_strategy": { "type": "string", "enum": ["sequential", "interleaved", "spaced", "custom"] },
        "priority": { "type": "integer", "minimum": 0 },
        "peer_zone": { "type": "string" },
        "transceiver_module_type": { "type": "string" }
      }
    },
    "connection": {
      "type": "object",
      "required": ["server_class", "connection_id", "nic", "ports_per_connection", "target_zone", "speed"],
      "properties": {
        "server_class": { "type": "string" },
        "connection_id": { "type": "string" },
        "connection_name": { "type": "string" },
        "nic": { "type": "string" },
        "port_index": { "type": "integer", "minimum": 0 },
        "ports_per_connection": { "type": "integer", "minimum": 1 },
        "hedgehog_conn_type": { "type": "string", "enum": ["unbundled", "bundled", "mclag", "eslag"] },
        "distribution": { "type": "string", "enum": ["same-switch", "alternating", "rail-optimized"] },
        "target_zone": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "speed": { "type": "integer", "minimum": 1 },
        "rail": { "type": "integer", "minimum": 0 },
        "port_type": { "type": "string", "enum": ["data", "ipmi", "pxe"] },
        "transceiver_module_type": { "type": "string" }
      }
    }
  }
}
